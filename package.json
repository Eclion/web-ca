{
  "name": "cancer-automata-spa",
  "version": "0.1.0",
  "description": "Browser SPA reimplementation of the Cancer-AutoMata MATLAB cellular automaton (Rust/WASM compute core).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "wasm": "wasm-pack build ./core-wasm --target web --out-dir ../src/wasm --out-name core_wasm",
    "wasm:dev": "wasm-pack build ./core-wasm --dev --target web --out-dir ../src/wasm --out-name core_wasm",
    "predev": "npm run wasm",
    "dev": "vite",
    "prebuild": "npm run wasm",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pretest": "npm run wasm",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "comlink": "^4.4.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "uplot": "^1.6.32",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.9.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  }
}
